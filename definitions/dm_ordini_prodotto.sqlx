config {
  type: "table",
  database: "ornate-crossbar-499808-h8",
  schema: "dvt",
  name: "dm_ordini_prodotto",
  description: "Numero di ordini per prodotto",
  columns: {
    id_prodotto: "Identificativo del prodotto",
    n_ordini: "Numero totale di ordini per il prodotto"
  }
}

SELECT
  id_prodotto,
  COUNT(*) AS n_ordini
FROM ${ref("t_source")}
GROUP BY id_prodotto
